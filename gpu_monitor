#!/bin/bash
set -eo pipefail
# ====================== 全局配置区 ======================
LOG_FILE="/tmp/gpu_monitor.log"
PID_FILE="/tmp/gpu_monitor.pid"
# GPU监控参数
MONITOR_GPU_ID="0"
GPU_LOAD_THRESHOLD=5
MEM_LOAD_THRESHOLD=10
CHECK_INTERVAL=10
# QQ发件邮箱配置（替换为你真实16位授权码）
MAIL_FROM="QQ发件邮箱"
MAIL_SMTP="smtp.qq.com:587"
MAIL_AUTH_USER="QQ发件邮箱"
MAIL_AUTH_PASS="真实16位授权码"
# 固定告警接收邮箱
MAIL_TARGET="接收邮箱"
# =======================================================

# 日志打印函数
write_log(){
    local now
    now=$(date "+%Y-%m-%d %H:%M:%S")
    echo "[$now] $1" >> "$LOG_FILE"
}

# 进程退出清理PID文件
cleanup(){
    rm -f "$PID_FILE"
    exit 0
}

# 邮件发送函数（修复旧版mutt兼容性，临时rc文件方案）
send_mail(){
    local mail_body="$1"
    local mail_title="【GPU闲置告警】云服务器即将自动关机"
    # 生成临时mutt配置文件
    local mutt_rc=$(mktemp /tmp/mutt_XXXX.rc)
    cat > "$mutt_rc" <<RC
set from="$MAIL_FROM"
set smtp_url="smtp://$MAIL_AUTH_USER@$MAIL_SMTP"
set smtp_pass="$MAIL_AUTH_PASS"
set ssl_starttls=yes
set ssl_force_tls=yes
RC
    # 发送邮件
    mutt -F "$mutt_rc" -s "$mail_title" -- "$MAIL_TARGET" <<MAIL
$mail_body
MAIL
    local send_ret=$?
    rm -f "$mutt_rc"
    if [ "$send_ret" -eq 0 ];then
        write_log "告警邮件发送成功，收件人：$MAIL_TARGET"
    else
        write_log "告警邮件发送失败，错误码:$send_ret，请检查QQ授权码、IMAP/POP3服务"
    fi
}

# GPU环境检测（无GPU直接退出，适配无卡云主机）
check_gpu(){
    if ! command -v nvidia-smi &> /dev/null;then
        write_log "当前服务器未安装NVIDIA驱动，无GPU设备，监控进程退出"
        exit 0
    fi
    local gpu_count
    gpu_count=$(nvidia-smi --query-gpu=name --format=csv,noheader,nounits 2>/dev/null | wc -l)
    if [ "$gpu_count" -eq 0 ];then
        write_log "nvidia-smi可用，但未识别到GPU硬件，监控进程退出"
        exit 0
    fi
    write_log "GPU环境校验通过，识别显卡总数：$gpu_count，开始监控"
}

# 获取单卡负载，N/A空值兜底为0
get_gpu_util(){
    local gpu_idx="$1"
    local gpu_usage mem_usage
    gpu_usage=$(nvidia-smi -i "$gpu_idx" --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | sed 's/N\/A/0/; s/ //g')
    mem_usage=$(nvidia-smi -i "$gpu_idx" --query-gpu=utilization.memory --format=csv,noheader,nounits 2>/dev/null | sed 's/N\/A/0/; s/ //g')
    gpu_usage=${gpu_usage:-0}
    mem_usage=${mem_usage:-0}
    echo "$gpu_usage $mem_usage"
}

# 拼接全部监控GPU负载文本
get_all_gpu_info(){
    local info_str=""
    IFS=',' read -ra gpu_arr <<< "$MONITOR_GPU_ID"
    for g in "${gpu_arr[@]}";do
        g=$(echo "$g" | tr -d ' ')
        read gu mu <<< $(get_gpu_util "$g")
        info_str+="GPU${g}:算力负载${gu}% | 显存负载${mu}%  "
    done
    echo "${info_str%  }"
}

# 判断所有监控GPU是否全部空闲
is_all_gpu_idle(){
    IFS=',' read -ra gpu_arr <<< "$MONITOR_GPU_ID"
    for g in "${gpu_arr[@]}";do
        g=$(echo "$g" | tr -d ' ')
        read gu mu <<< $(get_gpu_util "$g")
        if [ "$gu" -gt "$GPU_LOAD_THRESHOLD" ] || [ "$mu" -gt "$MEM_LOAD_THRESHOLD" ];then
            return 1 # 存在任务，非空闲
        fi
    done
    return 0 # 全部空闲
}

# 使用帮助文档
show_help(){
    cat <<HELP
==== GPU闲置自动关机监控脚本 ====
使用语法：
    bash $0 【闲置阈值(分钟)】 【关机倒计时(分钟)】
示例：
    bash $0 60 10
含义：GPU连续闲置60分钟，发送邮件至s202420211054@stu.tyust.edu.cn，10分钟后自动关机
适配场景：无GPU云服务器会自动退出监控，不会报错阻塞
HELP
    exit 1
}

# 主业务逻辑
main(){
    local idle_threshold="$1"
    local shutdown_wait="$2"

    # 参数数量校验
    if [ $# -ne 2 ];then
        write_log "启动失败：参数数量错误"
        show_help
    fi
    # 参数数字校验
    if ! [[ "$idle_threshold" =~ ^[0-9]+$ ]] || ! [[ "$shutdown_wait" =~ ^[0-9]+$ ]];then
        write_log "启动失败：闲置阈值、关机倒计时必须为纯数字"
        show_help
    fi
    # 依赖校验
    if ! command -v mutt &> /dev/null;then
        write_log "启动失败：系统未安装mutt邮件工具，请执行 apt install mutt"
        exit 1
    fi
    if ! command -v shutdown &> /dev/null;then
        write_log "启动失败：系统缺少shutdown关机命令"
        exit 1
    fi

    # 防重复启动PID锁
    if [ -f "$PID_FILE" ];then
        local old_pid
        old_pid=$(cat "$PID_FILE")
        if kill -0 "$old_pid" 2>/dev/null;then
            write_log "监控进程已运行(PID:$old_pid)，禁止重复启动"
            exit 1
        else
            rm -f "$PID_FILE"
        fi
    fi
    echo "$$" > "$PID_FILE"
    trap cleanup SIGINT SIGTERM EXIT

    # 校验GPU，无卡直接退出
    check_gpu

    write_log "================GPU监控服务启动================"
    write_log "配置：闲置阈值${idle_threshold}min，关机倒计时${shutdown_wait}min，告警邮箱${MAIL_TARGET}"
    local idle_total_min=0

    # 循环监控
    while true;do
        local load_info
        load_info=$(get_all_gpu_info)

        if is_all_gpu_idle;then
            # 累加闲置时长
            idle_total_min=$(echo "scale=2; $idle_total_min + $CHECK_INTERVAL/60" | bc)
            write_log "GPU全部闲置，实时负载[$load_info]，累计闲置${idle_total_min}min，阈值${idle_threshold}min"

            # 闲置超时触发关机流程
            if (( $(echo "$idle_total_min >= $idle_threshold" | bc -l) ));then
                # 清除历史定时关机，避免叠加
                shutdown -c 2>/dev/null || true
                local server_ip
                server_ip=$(hostname -I | awk '{print $1}')
                server_ip=${server_ip:-未知IP}
                local trigger_time=$(date "+%Y-%m-%d %H:%M:%S")
                local mail_content=$(cat <<MAIL
【GPU闲置自动关机告警】
服务器IP：$server_ip
告警触发时间：$trigger_time
累计闲置时长：${idle_total_min} 分钟
设定闲置阈值：${idle_threshold} 分钟
关机倒计时：${shutdown_wait} 分钟
触发瞬间GPU负载：$load_info

取消关机命令：
sudo shutdown -c
MAIL
)
                send_mail "$mail_content"
                write_log "闲置超时，${shutdown_wait}分钟后自动关机，执行 shutdown -c 可取消关机"
                shutdown -h +"$shutdown_wait" "GPU闲置超过${idle_threshold}分钟，自动关机"
                exit 0
            fi
        else
            # 检测到GPU任务，重置计时器
            if (( $(echo "$idle_total_min > 0" | bc -l) ));then
                write_log "检测到GPU运行任务，实时负载[$load_info]，重置闲置计时"
                idle_total_min=0
            else
                write_log "GPU存在运行任务，实时负载[$load_info]"
            fi
        fi
        sleep "$CHECK_INTERVAL"
    done
}

# ========== 全局代码段（移除local，修复语法报错） ==========
# 初始化日志文件
touch "$LOG_FILE"
chmod 644 "$LOG_FILE"
# 简易日志轮转：超过5000行清空日志（全局变量不写local）
log_lines=$(wc -l < "$LOG_FILE")
if [ "$log_lines" -gt 5000 ];then
    echo "[$(date "+%Y-%m-%d %H:%M:%S")] 日志行数超限，自动清空历史日志" > "$LOG_FILE"
fi

# 移除旧版不兼容的全局MUTT_CONFIG变量，改用函数内临时rc
unset MUTT_CONFIG

# 启动主程序
main "$1" "$2"
